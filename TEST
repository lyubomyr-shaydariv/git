__test 'git-check-ref-format: cannot have ASCII control characters (i.e. bytes whose values are lower than \040, or \177 DEL), space, tilde ~, caret ^, or colon : anywhere' 'refs/heads/^master'
__test 'git-check-ref-format: cannot have ASCII control characters (i.e. bytes whose values are lower than \040, or \177 DEL), space, tilde ~, caret ^, or colon : anywhere' 'refs/heads/:master'
__test 'git-check-ref-format: cannot have question-mark ?, asterisk *, or open bracket [ anywhere' 'refs/heads/?master'
